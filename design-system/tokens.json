{
  "$schema": "https://schemas.amzn.com/style-dictionary/v3.json",
  "_meta": {
    "name": "Mohanji Design Tokens",
    "version": "0.1.0",
    "description": "Source of truth for Mohanji digital properties. Style Dictionary compatible. Convert to platform-specific outputs (CSS, SCSS, JS, Android, iOS) via the Style Dictionary CLI.",
    "logoConvention": "Mohanji<em>.</em> — italic gold period after the wordmark."
  },

  "color": {
    "surface": {
      "white":      { "value": "#fdfcf9", "comment": "Default page bg" },
      "white-soft": { "value": "#faf7f0", "comment": "Alt sections, cards" },
      "white-warm": { "value": "#f5efe2", "comment": "Announce bars" },
      "cream":      { "value": "#faf4e6", "comment": "Faint warmth" }
    },
    "ink": {
      "default": { "value": "#2a241b" },
      "soft":    { "value": "#5a5347" },
      "mute":    { "value": "#8a8278" },
      "deep":    { "value": "#1a1510" },
      "black":   { "value": "#0a0908" }
    },
    "gold": {
      "default": { "value": "#b8924a", "comment": "Primary brand accent" },
      "light":   { "value": "#d4ae6b" },
      "deep":    { "value": "#8a6a2f" },
      "bright":  { "value": "#f2d48a", "comment": "On-black highlight" },
      "whisper": { "value": "#f0e6ce" }
    },
    "kailash": {
      "_comment": "Sky-blue palette from the official Kailash With Mohanji logo. Use ONLY on the Kailash yatra microsite/sections.",
      "brand":      { "value": "#1c94cc" },
      "brand-light":{ "value": "#54b5db" },
      "brand-deep": { "value": "#0e6b99" },
      "brand-ink":  { "value": "#0a4c72" },
      "brand-pale": { "value": "#e8f3fa" }
    },
    "event": {
      "_comment": "Semantic colours for journey/event cards & calendar bars.",
      "satsang":     { "value": "#8a6a2f", "comment": "Warm gold" },
      "retreat":     { "value": "#4a6b5a", "comment": "Forest green" },
      "pilgrimage":  { "value": "#9a4a3a", "comment": "Terracotta" },
      "immersion":   { "value": "#4a5a7a", "comment": "Slate blue" },
      "festival":    { "value": "#b8924a", "comment": "Gold" },
      "external":    { "value": "#6a6055", "comment": "Invited / external" }
    },
    "line": {
      "default":      { "value": "rgba(42,36,27,0.08)" },
      "strong":       { "value": "rgba(42,36,27,0.16)" },
      "gold":         { "value": "rgba(184,146,74,0.30)" },
      "gold-strong":  { "value": "rgba(184,146,74,0.55)" },
      "on-dark":      { "value": "rgba(201,161,78,0.22)" }
    }
  },

  "font": {
    "family": {
      "serif": { "value": "'Cormorant Garamond', 'Times New Roman', Georgia, serif", "comment": "Display + editorial" },
      "sans":  { "value": "'Manrope', -apple-system, system-ui, 'Segoe UI', sans-serif", "comment": "Body + UI" }
    },
    "weight": {
      "light":    { "value": "300" },
      "regular":  { "value": "400" },
      "medium":   { "value": "500" },
      "semibold": { "value": "600" }
    }
  },

  "size": {
    "type": {
      "hero":    { "value": "clamp(58px, 7vw, 118px)" },
      "display": { "value": "clamp(46px, 5vw, 84px)" },
      "h1":      { "value": "clamp(44px, 4.8vw, 68px)" },
      "h2":      { "value": "clamp(36px, 4vw, 56px)" },
      "h3":      { "value": "32px" },
      "h4":      { "value": "24px" },
      "lede":    { "value": "clamp(19px, 1.6vw, 24px)" },
      "body":    { "value": "16px" },
      "small":   { "value": "14px" },
      "caption": { "value": "12px" },
      "kicker":  { "value": "11px" },
      "micro":   { "value": "10px" }
    },
    "leading": {
      "display": { "value": "0.96" },
      "tight":   { "value": "1.04" },
      "snug":    { "value": "1.25" },
      "body":    { "value": "1.7" },
      "loose":   { "value": "1.85" }
    },
    "tracking": {
      "display":    { "value": "-0.024em" },
      "h2":         { "value": "-0.018em" },
      "h3":         { "value": "-0.01em" },
      "body":       { "value": "0" },
      "kicker":     { "value": "0.26em", "comment": "Uppercase labels" },
      "kicker-lg":  { "value": "0.36em" },
      "kicker-xl":  { "value": "0.42em", "comment": "Hero kickers" }
    }
  },

  "space": {
    "_comment": "4px base. Use semantic tokens (section-y-*, container-*) over raw values when possible.",
    "1":  { "value": "4px"  },
    "2":  { "value": "8px"  },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "10": { "value": "40px" },
    "12": { "value": "48px" },
    "14": { "value": "56px" },
    "16": { "value": "64px" },
    "20": { "value": "80px" },
    "24": { "value": "96px" },
    "30": { "value": "120px" },
    "36": { "value": "144px" },
    "44": { "value": "176px" },

    "section": {
      "y-sm":      { "value": "80px"  },
      "y-md":      { "value": "120px" },
      "y-lg":      { "value": "140px" },
      "y-xl":      { "value": "160px" },
      "x":         { "value": "48px"  },
      "x-mobile":  { "value": "24px"  }
    },
    "container": {
      "narrow": { "value": "820px"  },
      "prose":  { "value": "900px"  },
      "wide":   { "value": "1200px" },
      "full":   { "value": "1400px" }
    }
  },

  "radius": {
    "none": { "value": "0",     "comment": "Default — sharp editorial feel" },
    "sm":   { "value": "2px"    },
    "pill": { "value": "999px",  "comment": "Calendar event bars" }
  },

  "shadow": {
    "card":     { "value": "0 20px 60px rgba(138,106,47,0.15)" },
    "card-sm":  { "value": "0 8px 30px rgba(42,36,27,0.08)" },
    "hero":     { "value": "0 10px 80px rgba(0,0,0,0.7)" },
    "glow":     { "value": "0 0 100px rgba(240,230,206,0.5)" }
  },

  "motion": {
    "duration": {
      "fast": { "value": "180ms" },
      "base": { "value": "300ms" },
      "slow": { "value": "500ms" },
      "page": { "value": "800ms" }
    },
    "easing": {
      "in-out": { "value": "cubic-bezier(0.4, 0, 0.2, 1)" },
      "out":    { "value": "cubic-bezier(0.16, 1, 0.3, 1)" }
    }
  },

  "z": {
    "base":    { "value": "0"   },
    "sticky":  { "value": "50"  },
    "overlay": { "value": "100" },
    "modal":   { "value": "200" },
    "grain":   { "value": "300" }
  }
}
